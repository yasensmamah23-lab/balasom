        </div>

        <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 overflow-x-auto">
            <h2 class="text-lg font-bold mb-4">سجل الطلبات والتقييم</h2>
            <table class="w-full text-right">
                <thead>
                    <tr class="text-slate-400 border-b">
                        <th class="pb-3 px-2">الخدمة</th>
                        <th class="pb-3 px-2">التاريخ</th>
                        <th class="pb-3 px-2">الحالة</th>
                        <th class="pb-3 px-2">التقييم</th>
                    </tr>
                </thead>
                <tbody class="text-slate-700">
                    <tr class="border-b">
                        <td class="py-4 px-2 font-medium">ضماد جروح منزلية</td>
                        <td class="py-4 px-2">2026-06-28</td>
                        <td class="py-4 px-2">
                            <span class="bg-blue-100 text-blue-600 px-3 py-1 rounded-full text-xs font-bold">قيد المراجعة</span>
                        </td>
                        <td class="py-4 px-2 text-slate-400 italic text-sm">بانتظار الإتمام...</td>
                    </tr>
                    <tr class="border-b bg-slate-50/50">
                        <td class="py-4 px-2 font-medium">رعاية كبار السن (8 ساعات)</td>
                        <td class="py-4 px-2">2026-06-20</td>
                        <td class="py-4 px-2">
                            <span class="bg-green-100 text-green-600 px-3 py-1 rounded-full text-xs font-bold">مكتملة</span>
                        </td>
                        <td class="py-4 px-2">
                            <div class="flex items-center space-x-1 space-x-reverse">
                                <a href="#" class="text-yellow-500 hover:scale-110 transition"><i class="fa-solid fa-star"></i></a>
                                <a href="#" class="text-yellow-500 hover:scale-110 transition"><i class="fa-solid fa-star"></i></a>
                                <a href="#" class="text-yellow-500 hover:scale-110 transition"><i class="fa-solid fa-star"></i></a>
                                <a href="#" class="text-yellow-500 hover:scale-110 transition"><i class="fa-solid fa-star"></i></a>
                                <a href="#" class="text-slate-300 hover:text-yellow-500 transition"><i class="fa-solid fa-star"></i></a>
                                <span class="text-xs mr-2 text-blue-600 font-bold underline">إضافة ملاحظة</span>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <footer class="mt-12 py-6 text-center border-t border-slate-200">
        <p class="text-slate-500 text-sm font-bold">منصة بلسم: الجودة في الرعاية التمريضية</p>
    </footer>
</body>
</html>
